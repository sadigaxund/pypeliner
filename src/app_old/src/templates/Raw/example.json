{
    "kafka": {
      "topic": # KAFKA TOPIC NAME,
      "partitions": # NUMBER OF PARTITIONS,
      "replication": # NUMBER OF REPLICAS,
      "config": {
        "max.message.bytes": # MAX SIZE OF A MESSAGE IN BYTES,
        "retention.ms": # THE AMOUNT OF TIME TO KEEP THE MESSAGE IN KAFKA TOPIC,
      }
    },
    "apify": {
      "id": # STRING VERSION OF ACTOR ID,
      "hash": # HASHED VERSION OF ACTOR ID,
      "build": # BUILD NUMBER OF ACTOR,
      "recurrent-limiters": {
        "interval": # qTHE INTERVAL BETWEEN RUNS. FREQUENCY OF RECURRENCY,
        "timeout": # THE AMOUNT OF TIME AFTER RUN STOPS,
        "memory": # MAX ALLOCATED MEMORY FOR RUN AT APIFY'S COMPUTING SERVER,
        "maxItems": # MAX NUMBER OF ITEMS TO BE CHARGED IN A RUN,
    },
      "bootstrap-limiters": {
        # LIMITERS FOR BOOTSTRAP RUNS, SEE ABOVE FOR KEYS
        # IF NOT PROVIDED, DEFAULTS WILL BE SELECTED 
    },
      "date-key": # A KEY THAT REPRESENTS FOR RECURRENCY #,
      "input": {# INPUT FROM APIFY ACTOR #}
    }
  }
  
  